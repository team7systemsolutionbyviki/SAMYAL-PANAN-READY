rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Allow user creation if they are the owner or if the creator is an admin
      allow create: if isOwner(userId) || isAdmin();
      // Allow user updates if they are the owner or if the updater is an admin
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- Products, Categories, Units, Locations, Coupons ---
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /units/{unitId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /locations/{locationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Orders Collection ---
    match /orders/{orderId} {
      // Users can read their own orders; admins can read all orders
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      // Users can place orders (write) associated with their own uid
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Only admins can update order status or delete orders
      allow update, delete: if isAdmin();
    }

    // --- Contacts Form Messages & Custom Event Orders ---
    match /contacts/{contactId} {
      allow read: if isAdmin();
      allow create: if true; // anyone can send a message
      allow update, delete: if isAdmin();
    }

    match /custom_orders/{customOrderId} {
      allow read: if isAdmin();
      allow create: if true; // anyone can request a custom catering order
      allow update, delete: if isAdmin();
    }

    // --- Admin-Only Panels (Expenses, Inventory, Purchases, Payments) ---
    match /expenses/{expenseId} {
      allow read, write: if isAdmin();
    }

    match /expense_categories/{catId} {
      allow read, write: if isAdmin();
    }

    match /inventory_items/{itemId} {
      allow read, write: if isAdmin();
    }

    match /purchases/{purchaseId} {
      allow read, write: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read, write: if isAdmin();
    }

    // --- Reviews Collection ---
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if (isAuthenticated() && request.resource.data.userId == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin();
    }

    // --- Store Settings ---
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
